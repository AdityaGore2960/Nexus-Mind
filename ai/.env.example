# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=nexus-mind-ai
APP_VERSION=0.1.0
ENV=development
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
WORKERS=1

# ── Database (PostGIS) ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexusmind
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
SECRET_KEY=CHANGE_ME_openssl_rand_hex_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=200
RATE_LIMIT_WINDOW_SECONDS=60

# ── Object Storage ────────────────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL blank for real AWS; set for MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=ap-south-1
S3_BUCKET_RAW=nexus-raw
S3_BUCKET_PROCESSED=nexus-processed
S3_BUCKET_ML=nexus-ml

# ── ML ────────────────────────────────────────────────────────────────────────
MODEL_REGISTRY_PATH=models/
INFERENCE_BATCH_SIZE=64
DEVICE=cpu          # cpu | cuda | mps

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text     # text (dev) | json (prod)

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Downstream ────────────────────────────────────────────────────────────────
GATEWAY_URL=http://localhost:8000
